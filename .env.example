# Ejemplo de configuración de WhatsApp para archivo .env

# Habilitar/deshabilitar WhatsApp (true/false)
WHATSAPP_ENABLED=true

# Token de acceso a Meta Cloud API
# Obtén este token en: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=EAAx...tus_token_aqui...

# ID del número de teléfono WhatsApp Business
# Obtén este ID en WhatsApp Business > API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ID de la cuenta de negocio (opcional)
WHATSAPP_BUSINESS_ACCOUNT_ID=987654321098765
